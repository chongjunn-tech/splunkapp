<form version="1.1" script="compliance_audit.js" stylesheet="compliance_audit.css">
  <label>Compliance - Local Users &amp; Group Review</label>
  <description>
  Annual review of local user account compliance. 
  Each hostname reflects its latest audit job. 
  Account baselines are maintained by the team in Azure DevOps.
   </description>

  <init>
    <set token="review_type_label">Compliance - Local Users Review</set>
  </init>

  <fieldset submitButton="true" autoRun="true">

    <input type="dropdown" token="service_catalog" searchWhenChanged="true">
      <label>Service Catalog</label>
      <default>user</default>
      <initialValue>user</initialValue>
      <choice value="user">Compliance - Local Users Review</choice>
      <choice value="group">Compliance - Local Group Review</choice>
      <!-- Reset all downstream filters when service catalog changes -->
      <change>
        <condition value="user">
          <set token="review_type_label">Compliance - Local Users Review</set>
        </condition>
        <condition value="group">
          <set token="review_type_label">Compliance - Local Group Review</set>
        </condition>
        <set token="filter_device">*</set>
        <set token="form.filter_device">*</set>
        <set token="filter_dept">*</set>
        <set token="form.filter_dept">*</set>
        <set token="filter_host">*</set>
        <set token="form.filter_host">*</set>
      </change>
    </input>

    <input type="dropdown" token="filter_device" searchWhenChanged="true">
      <label>Device Type</label>
      <default>*</default>
      <choice value="*">-- All Devices --</choice>
      <search>
        <query>
          index=automation_local_user_group_audit sourcetype="custom:automation_local_user_group_audit:logs"
          | spath input=_raw path=compliance_review_type output=compliance_review_type
          | spath input=_raw path=device output=device
          | where compliance_review_type="$service_catalog$"
          | stats count by device | fields device
        </query>
      </search>
      <fieldForLabel>device</fieldForLabel>
      <fieldForValue>device</fieldForValue>
      <!-- Reset department and hostname when device changes -->
      <change>
        <set token="filter_dept">*</set>
        <set token="form.filter_dept">*</set>
        <set token="filter_host">*</set>
        <set token="form.filter_host">*</set>
      </change>
    </input>

    <input type="dropdown" token="filter_dept" searchWhenChanged="true">
      <label>Department</label>
      <default>*</default>
      <choice value="*">-- All Departments --</choice>
      <search>
        <query>
          index=automation_local_user_group_audit sourcetype="custom:automation_local_user_group_audit:logs"
          | spath input=_raw path=compliance_review_type output=compliance_review_type
          | spath input=_raw path=department output=department
          | where compliance_review_type="$service_catalog$" AND (device="$filter_device$" OR "$filter_device$"="*")
          | stats count by department | fields department
        </query>
      </search>
      <fieldForLabel>department</fieldForLabel>
      <fieldForValue>department</fieldForValue>
      <!-- Reset hostname when department changes -->
      <change>
        <set token="filter_host">*</set>
        <set token="form.filter_host">*</set>
      </change>
    </input>

    <input type="dropdown" token="filter_host" searchWhenChanged="true" depends="$filter_dept$">
      <label>Hostname</label>
      <default>*</default>
      <choice value="*">-- All Hosts --</choice>
      <search>
        <query>
          index=automation_local_user_group_audit sourcetype="custom:automation_local_user_group_audit:logs"
          | spath input=_raw path=compliance_review_type output=compliance_review_type
          | spath input=_raw path=device output=device
          | spath input=_raw path=department output=department
          | spath input=_raw path=hostname output=hostname
          | where compliance_review_type="$service_catalog$" AND (device="$filter_device$" OR "$filter_device$"="*") AND (department="$filter_dept$" OR "$filter_dept$"="*")
          | stats count by hostname | fields hostname
        </query>
      </search>
      <fieldForLabel>hostname</fieldForLabel>
      <fieldForValue>hostname</fieldForValue>
    </input>

  </fieldset>

  <!-- AUDIT TABLE — rendered by JS for checkbox support -->
  <row>
    <panel>
      <title>$review_type_label$</title>
      <html>
        <div id="audit-search-status" style="padding:8px;color:#6b7280;font-size:12px;">Loading...</div>
        <div id="audit-table-container"></div>
        <div id="audit-pager" style="display:flex;align-items:center;gap:4px;margin-top:10px;flex-wrap:wrap;"></div>
        <div id="audit-action-bar" style="display:none;padding:12px 0;border-top:1px solid #e5e7eb;margin-top:8px;">
          <span id="audit-selected-count" style="font-size:13px;color:#374151;margin-right:16px;"></span>
          <button id="review-btn"
            style="padding:8px 24px;font-size:13px;font-weight:bold;
                   border:none;border-radius:4px;cursor:pointer;
                   background:#1d4ed8;color:#fff;">
            Mark Selected as Reviewed
          </button>
          <span id="review-feedback" style="margin-left:16px;font-size:12px;"></span>
        </div>
      </html>
    </panel>
  </row>

  <!-- SIGN-OFF HISTORY -->
  <row>
    <panel>
      <title>Sign-off History</title>
      <table>
        <search>
          <query>
            index=automation_local_user_group_audit sourcetype="user_audit_signoff"
            event_type="audit_signoff"
            | eval "Signed Off At" = strftime(_time, "%d %b %Y %H:%M:%S")
            | table "Signed Off At" hostname reviewed_by remarks
            | rename hostname    as "Host"
                     reviewed_by as "Reviewed By"
                     remarks     as "Remarks"
            | sort -"Signed Off At"
          </query>
          <refresh>30s</refresh>
        </search>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

</form>