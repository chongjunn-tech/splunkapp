<form version="1.1" script="compliance_audit.js" stylesheet="compliance_audit.css">
  <label>Compliance - Local Users Review</label>
  <description>Annual local user account compliance review. Baselines managed in GitLab by team.</description>

  <fieldset submitButton="true" autoRun="true">
    <input type="dropdown" token="service_catalog" searchWhenChanged="false">
      <label>Service Catalog</label>
      <default>Compliance - Local Users Review</default>
      <choice value="Compliance - Local Users Review">Compliance - Local Users Review</choice>
    </input>
    <input type="dropdown" token="filter_dept" searchWhenChanged="true">
      <label>Department</label>
      <default>*</default>
      <choice value="*">-- All Departments --</choice>
      <search>
        <query>
          index=automation_local_user_group_audit sourcetype="custom:automation_local_user_group_audit:logs"
          | spath input=_raw path=department output=department
          | stats count by department | fields department
        </query>
      </search>
      <fieldForLabel>department</fieldForLabel>
      <fieldForValue>department</fieldForValue>

      <!-- Reset hostname when department changes -->
      <change>
        <set token="filter_host">*</set>
        <set token="form.filter_host">*</set>
      </change>

    </input>

    <input type="dropdown" token="filter_host" searchWhenChanged="true" depends="$filter_dept$">
      <label>Hostname</label>
      <default>*</default>
      <choice value="*">-- All Hosts --</choice>
      <search>
        <query>
          index=automation_local_user_group_audit sourcetype="custom:automation_local_user_group_audit:logs"
          | spath input=_raw path=department output=department
          | spath input=_raw path=hostname output=hostname
          | where (department="$filter_dept$" OR "$filter_dept$"="*")
          | stats count by hostname | fields hostname
        </query>
      </search>
      <fieldForLabel>hostname</fieldForLabel>
      <fieldForValue>hostname</fieldForValue>
    </input>
  </fieldset>

  <!-- AUDIT TABLE — rendered by JS for checkbox support -->
  <row>
    <panel>
      <title>Compliance - Local Users Review</title>
      <html>
        <div id="audit-search-status" style="padding:8px;color:#6b7280;font-size:12px;">Loading...</div>
        <div id="audit-table-container"></div>
        <div id="audit-action-bar" style="display:none;padding:12px 0;border-top:1px solid #e5e7eb;margin-top:8px;">
          <span id="audit-selected-count" style="font-size:13px;color:#374151;margin-right:16px;"></span>
          <button id="review-btn"
            style="padding:8px 24px;font-size:13px;font-weight:bold;
                   border:none;border-radius:4px;cursor:pointer;
                   background:#1d4ed8;color:#fff;">
            Mark Selected as Reviewed
          </button>
          <span id="review-feedback" style="margin-left:16px;font-size:12px;"></span>
        </div>
      </html>
    </panel>
  </row>

  <!-- SIGN-OFF HISTORY -->
  <row>
    <panel>
      <title>Sign-off History</title>
      <table>
        <search>
          <query>
            index=automation_local_user_group_audit sourcetype="user_audit_signoff"
            event_type="audit_signoff"
            | eval "Signed Off At" = strftime(_time, "%d %b %Y %H:%M:%S")
            | table "Signed Off At" hostname reviewed_by audit_year decision remarks
            | rename hostname    as "Host"
                     reviewed_by as "Reviewed By"
                     audit_year  as "Year"
                     decision    as "Decision"
                     remarks     as "Remarks"
            | sort -"Signed Off At"
          </query>
          <refresh>30s</refresh>
        </search>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>

</form>